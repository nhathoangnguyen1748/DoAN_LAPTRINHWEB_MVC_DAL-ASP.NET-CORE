    function columnFlagSummary(column) {
        const flags = [];
        if (column.isPrimaryKey) flags.push('<span class="badge pk">PK</span>');
        if (column.foreignKeyTable) flags.push('<span class="badge fk">FK</span>');
        if (column.isUnique) flags.push('<span class="badge uq">UQ</span>');
        if (!column.isNullable) flags.push('<span class="badge req">REQ</span>');
        return flags.join('');
    }

    function typeLabel(type) {
        return String(type || '').replace(/\(.+\)/, '').toUpperCase();
