    function renderRelations() {
        const defs = elements.relationSvg.querySelector('defs')?.outerHTML || '';
        const paths = [];
        const labels = [];
        const relations = relationColumns();
        const activeTable = selectedTable();

        relations.forEach((relation, index) => {
            const targetTable = state.schema.tables.find(table => table.name.toLowerCase() === relation.column.foreignKeyTable.toLowerCase());
            if (!targetTable) return;

            const targetColumnName = relation.column.foreignKeyColumn || 'id';
            const targetColumn = targetTable.columns.find(column => column.name.toLowerCase() === targetColumnName.toLowerCase()) || targetTable.columns.find(column => column.isPrimaryKey) || targetTable.columns[0];
            if (!targetColumn) return;

            const leftToRight = relation.table.x <= targetTable.x;
            const start = columnAnchor(relation.table, relation.column, leftToRight ? 'right' : 'left');
            const end = columnAnchor(targetTable, targetColumn, leftToRight ? 'left' : 'right');
            
            // Sá»­ dá»¥ng cÃ¡c Ä‘oáº¡n tháº³ng vuÃ´ng gÃ³c (Orthogonal) káº¿t há»£p offset chá»‘ng Ä‘Ã¨
            const offset = 26 + (index % 5) * 18;
            const midX = leftToRight ? Math.max(start.x + offset, (start.x + end.x) / 2) : Math.min(start.x - offset, (start.x + end.x) / 2);
            const d = `M ${start.x} ${start.y} L ${midX} ${start.y} L ${midX} ${end.y} L ${end.x} ${end.y}`;

            let statusClass = '';
            if (activeTable) {
                const isRelated = relation.table.id === activeTable.id || targetTable.id === activeTable.id;
                statusClass = isRelated ? 'active' : 'dimmed';
            }

            paths.push(`<path class="relation-path ${statusClass}" d="${d}" marker-end="url(#arrowHead)"></path>`);
            labels.push(`<text class="relation-label ${statusClass}" x="${end.x + (leftToRight ? -44 : 14)}" y="${end.y - 8}">1</text>`);
            labels.push(`<text class="relation-label many ${statusClass}" x="${start.x + (leftToRight ? 12 : -46)}" y="${start.y - 8}">1..*</text>`);
        });

        elements.relationSvg.innerHTML = defs + paths.join('') + labels.join('');
    }

    function columnAnchor(table, column, side) {
        const sorted = [...table.columns].sort((a, b) => a.order - b.order);
        const index = Math.max(0, sorted.findIndex(candidate => candidate.id === column.id));
        return {
            x: table.x + (side === 'right' ? tableWidth : 0),
            y: table.y + headerHeight + index * rowHeight + rowHeight / 2
        };
    }

