@model DoAnLapTrinhWeb.Models.Projects.DesignerWorkspaceViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Database Designer";
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    var initialSchemaJson = JsonSerializer.Serialize(Model.Schema, jsonOptions);
    var currentProjectIdJson = JsonSerializer.Serialize(Model.CurrentProjectId, jsonOptions);
    var currentUserEmailJson = JsonSerializer.Serialize(Model.UserEmail, jsonOptions);
}

<section class="designer-shell">
    <aside class="control-panel">
        <div class="control-header">
            <p class="side-kicker">Control panel</p>
            <a class="chip-button exit-project-btn" asp-controller="Projects" asp-action="Index" aria-label="Back to project management"><-</a>
        </div>

        <div class="side-switch" role="tablist" aria-label="Designer panels">
            <button class="side-switch-item active" type="button" data-side-mode="tables">Tables</button>
            <button class="side-switch-item" type="button" data-side-mode="properties">Properties</button>
        </div>

        <div class="selection-strip">
            <span id="selectedTableName">No table</span>
            <span><span id="sidebarColumnCount">0 columns</span> | <span id="sidebarRelationCount">0 relations</span></span>
        </div>

        <div id="tablesPane" class="side-pane">
            <div class="side-card table-list-card">
                <div class="side-card-title">
                    <span>Schema tables</span>
                    <small id="tableCount">0</small>
                </div>
                <div class="table-tools">
                    <button class="chip-button chip-blue" type="button" data-add-table>+ New table</button>
                    <label class="search-field">
                        <span>Search</span>
                        <input id="tableSearchInput" type="search" placeholder="Search table or column" />
                    </label>
                </div>
                <div id="tableList" class="table-list"></div>
            </div>
        </div>

        <div id="propertiesPane" class="side-pane" hidden>
            <div class="side-card properties-card">
                <div class="properties-topline">
                    <p class="side-kicker">Properties</p>
                    <button class="icon-btn small" type="button" data-side-mode="tables" aria-label="Close properties">x</button>
                </div>
                <div id="inspectorContent" class="inspector-content"></div>
            </div>
        </div>
    </aside>

    <main class="designer-panel designer-canvas-panel">
        <div class="diagram-header">
            <div>
                <p class="section-kicker">Database</p>
                <h1>ER Diagram</h1>
                <p>DBeaver-style table view with column-level relation anchors.</p>
            </div>
            <div class="diagram-actions">
                <button id="openSqlModalBtn" class="btn btn-light" type="button">Import SQL</button>
                <button id="autoLayoutBtn" class="btn btn-light" type="button">Auto Arrange</button>
                <button id="reviewBtn" class="btn btn-light" type="button">
                    <span class="btn-spinner" aria-hidden="true"></span>
                    <span id="reviewBtnText">AI Review</span>
                </button>
                <button id="exportBtn" class="btn btn-light" type="button">Export MVC</button>
                <button id="addTableBtn" class="btn btn-primary" type="button">+ New table</button>
                <button id="deleteAllTablesBtn" class="btn btn-danger" type="button">x Delete all tables</button>
            </div>
        </div>

        <div class="canvas-frame">
            <div class="canvas-topbar">
                <div class="canvas-title-block">
                    <span class="canvas-icon">ER</span>
                    <div>
                        <strong>ER diagram canvas</strong>
                        <small>Selected: <span id="canvasSelectedName">none</span></small>
                    </div>
                </div>
                <div class="canvas-badges">
                    <span id="sqlStats" class="soft-pill">0 tables</span>
                    <span id="relationCount" class="soft-pill">0 relations</span>
                    <span class="soft-pill success">routed lanes</span>
                    <span class="soft-pill">Focus selection</span>
                    <div class="zoom-pill" role="group" aria-label="Canvas zoom controls">
                        <button id="zoomOutBtn" class="zoom-btn" type="button" aria-label="Zoom out">-</button>
                        <strong id="zoomLevelLabel">48%</strong>
                        <button id="zoomInBtn" class="zoom-btn" type="button" aria-label="Zoom in">+</button>
                        <button id="fitViewBtn" class="fit-view-btn" type="button">Fit view</button>
                    </div>
                </div>
            </div>

            <div id="canvasViewport" class="canvas-viewport">
                <div id="canvas" class="schema-canvas">
                    <svg id="relationSvg" class="relation-svg" width="1800" height="1200" viewBox="0 0 1800 1200" aria-hidden="true">
                        <defs>
                            <marker id="arrowHead" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto" markerUnits="strokeWidth">
                                <path d="M0,0 L0,6 L6,3 z" fill="currentColor"></path>
                            </marker>
                        </defs>
                    </svg>
                    <div id="tableLayer" class="table-layer"></div>
                    <div id="remoteCursorLayer" class="remote-cursor-layer"></div>
                    <div id="emptyCanvas" class="empty-canvas">
                        <div class="empty-icon">+</div>
                        <h3>No tables yet</h3>
                        <p>Import SQL or create a new table to start the diagram.</p>
                    </div>
                </div>
            </div>

            <div class="canvas-footer">
                <span>Project: <strong id="footerProjectName">GeneratedMvcApp</strong></span>
                <span id="canvasTipText">Tip: Ctrl + mouse wheel to zoom, drag table header to move.</span>
                <span>Selected: <strong id="footerSelectedTable">none</strong></span>
            </div>
        </div>
    </main>
</section>

<div id="sqlImportOverlay" class="review-overlay" hidden>
    <div class="review-dialog sql-import-dialog">
        <div class="review-header">
            <div>
                <p class="section-kicker">SQL Import</p>
                <h2>Import database structure</h2>
                <p>Paste CREATE TABLE statements, then choose merge or overwrite when needed.</p>
            </div>
            <button id="closeSqlImportBtn" class="icon-btn" type="button" aria-label="Close SQL import">x</button>
        </div>
        <label class="field-label" for="projectName">Project name</label>
        <input id="projectName" class="text-input" value="GeneratedMvcApp" />
        <label class="field-label" for="sqlInput">SQL script</label>
        <textarea id="sqlInput" class="sql-input" spellcheck="false" placeholder="Paste CREATE TABLE statements here..."></textarea>
        <button id="importSqlBtn" class="btn btn-primary wide" type="button">Import SQL</button>
    </div>
</div>

<div id="reviewOverlay" class="review-overlay" hidden>
    <div class="review-dialog">
        <div class="review-header">
            <div>
                <p class="section-kicker">AI Database Review</p>
                <h2 id="reviewTitle">Relationship review</h2>
                <p id="reviewSource">Database links only</p>
            </div>
            <div class="review-header-actions">
                <button id="fixAllReviewBtn" class="btn btn-ai" type="button" hidden>Fix all</button>
                <button id="closeReviewBtn" class="icon-btn" type="button" aria-label="Close review">x</button>
            </div>
        </div>
        <div class="review-summary-grid">
            <div><strong id="issueTotal">0</strong><span>Issues</span></div>
            <div class="high"><strong id="issueHigh">0</strong><span>High</span></div>
            <div class="medium"><strong id="issueMedium">0</strong><span>Medium</span></div>
            <div class="low"><strong id="issueLow">0</strong><span>Low</span></div>
        </div>
        <div id="reviewIssues" class="review-issues"></div>
    </div>
</div>

<div id="toast" class="toast-message" hidden></div>

<div id="importConfirmOverlay" class="review-overlay" hidden>
    <div class="review-dialog import-dialog">
        <div class="import-dialog-header">
            <p class="section-kicker">SQL Import</p>
            <h2>Import Options</h2>
            <p>Choose how you want to import the new tables into the database schema.</p>
        </div>
        <div class="import-choice-grid">
            <button id="importOverwriteBtn" class="btn btn-danger" type="button">Overwrite Schema</button>
            <button id="importMergeBtn" class="btn btn-primary no-offset" type="button">Merge Tables</button>
        </div>
        <button id="importCancelBtn" class="btn btn-light wide" type="button">Cancel</button>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
(() => {
    const initialSchema = @Html.Raw(initialSchemaJson);
    const currentProjectId = @Html.Raw(currentProjectIdJson);
    const currentUserEmail = @Html.Raw(currentUserEmailJson);
    const canvasSize = { width: 1800, height: 1200 };
    const tableWidth = 214;
    const headerHeight = 50;
    const rowHeight = 23;
    const minZoom = 0.35;
    const maxZoom = 1.3;
    const zoomStep = 0.08;
    const state = {
        schema: { projectName: 'GeneratedMvcApp', tables: [] },
        selectedTableId: null,
        selectedColumnId: null,
        dragging: null,
        lastReviewResult: null,
        fixingReview: false,
        sideMode: 'tables',
        propertyTab: 'columns',
        tableSearch: '',
        zoom: 0.48,
        projectId: currentProjectId,
        applyingRemoteUpdate: false,
        canvasEditTableId: null
    };

    const elements = {
        projectName: document.getElementById('projectName'),
        sqlInput: document.getElementById('sqlInput'),
        sqlImportOverlay: document.getElementById('sqlImportOverlay'),
        openSqlModalBtn: document.getElementById('openSqlModalBtn'),
        closeSqlImportBtn: document.getElementById('closeSqlImportBtn'),
        importSqlBtn: document.getElementById('importSqlBtn'),
        addTableBtn: document.getElementById('addTableBtn'),
        deleteAllTablesBtn: document.getElementById('deleteAllTablesBtn'),
        autoLayoutBtn: document.getElementById('autoLayoutBtn'),
        reviewBtn: document.getElementById('reviewBtn'),
        reviewBtnText: document.getElementById('reviewBtnText'),
        canvasTipText: document.getElementById('canvasTipText'),
        exportBtn: document.getElementById('exportBtn'),
        topExportBtn: document.getElementById('topExportBtn'),
        sqlStats: document.getElementById('sqlStats'),
        tableCount: document.getElementById('tableCount'),
        relationCount: document.getElementById('relationCount'),
        selectedTableName: document.getElementById('selectedTableName'),
        sidebarColumnCount: document.getElementById('sidebarColumnCount'),
        sidebarRelationCount: document.getElementById('sidebarRelationCount'),
        canvasSelectedName: document.getElementById('canvasSelectedName'),
        footerProjectName: document.getElementById('footerProjectName'),
        footerSelectedTable: document.getElementById('footerSelectedTable'),
        tablesPane: document.getElementById('tablesPane'),
        propertiesPane: document.getElementById('propertiesPane'),
        tableSearchInput: document.getElementById('tableSearchInput'),
        tableList: document.getElementById('tableList'),
        canvasViewport: document.getElementById('canvasViewport'),
        canvas: document.getElementById('canvas'),
        tableLayer: document.getElementById('tableLayer'),
        relationSvg: document.getElementById('relationSvg'),
        remoteCursorLayer: document.getElementById('remoteCursorLayer'),
        emptyCanvas: document.getElementById('emptyCanvas'),
        zoomOutBtn: document.getElementById('zoomOutBtn'),
        zoomInBtn: document.getElementById('zoomInBtn'),
        fitViewBtn: document.getElementById('fitViewBtn'),
        zoomLevelLabel: document.getElementById('zoomLevelLabel'),
        inspectorContent: document.getElementById('inspectorContent'),
        reviewOverlay: document.getElementById('reviewOverlay'),
        closeReviewBtn: document.getElementById('closeReviewBtn'),
        fixAllReviewBtn: document.getElementById('fixAllReviewBtn'),
        reviewTitle: document.getElementById('reviewTitle'),
        reviewSource: document.getElementById('reviewSource'),
        issueTotal: document.getElementById('issueTotal'),
        issueHigh: document.getElementById('issueHigh'),
        issueMedium: document.getElementById('issueMedium'),
        issueLow: document.getElementById('issueLow'),
        reviewIssues: document.getElementById('reviewIssues'),
        toast: document.getElementById('toast'),
        importConfirmOverlay: document.getElementById('importConfirmOverlay'),
        importOverwriteBtn: document.getElementById('importOverwriteBtn'),
        importMergeBtn: document.getElementById('importMergeBtn'),
        importCancelBtn: document.getElementById('importCancelBtn')
    };

    const collaboration = {
        connection: null,
        schemaTimer: null,
        cursorTimer: null,
        cursorColor: colorFromEmail(currentUserEmail),
        remoteCursors: new Map()
    };

    function uid() {
        if (window.crypto && crypto.randomUUID) {
            return crypto.randomUUID().replaceAll('-', '');
        }
        return Math.random().toString(16).slice(2) + Date.now().toString(16);
    }

    function colorFromEmail(email) {
        const palette = ['#1485f5', '#047857', '#b45309', '#be123c', '#7c3aed', '#0f766e', '#db2777'];
        const source = String(email || 'guest');
        let hash = 0;
        for (let index = 0; index < source.length; index++) {
            hash = ((hash << 5) - hash) + source.charCodeAt(index);
            hash |= 0;
        }
        return palette[Math.abs(hash) % palette.length];
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function normalizeSchema(schema) {
        state.schema = {
            projectName: schema.projectName || elements.projectName.value || 'GeneratedMvcApp',
            tables: (schema.tables || []).map((table, tableIndex) => ({
                id: table.id || uid(),
                name: table.name ?? `table_${tableIndex + 1}`,
                lastValidName: table.lastValidName || table.name || `table_${tableIndex + 1}`,
                x: Number.isFinite(Number(table.x)) ? Number(table.x) : 85 + (tableIndex % 3) * 330,
                y: Number.isFinite(Number(table.y)) ? Number(table.y) : 55 + Math.floor(tableIndex / 3) * 220,
                columns: (table.columns || []).map((column, columnIndex) => ({
                    id: column.id || uid(),
                    name: column.name || `column_${columnIndex + 1}`,
                    sqlType: column.sqlType || 'nvarchar(255)',
                    isPrimaryKey: Boolean(column.isPrimaryKey),
                    isNullable: column.isPrimaryKey ? false : column.isNullable !== false,
                    isUnique: Boolean(column.isUnique),
                    foreignKeyTable: column.foreignKeyTable || '',
                    foreignKeyColumn: column.foreignKeyColumn || '',
                    order: Number.isFinite(Number(column.order)) ? Number(column.order) : columnIndex
                }))
            }))
        };
        elements.projectName.value = state.schema.projectName;
        if (state.schema.tables.length === 0) {
            state.selectedTableId = null;
            state.selectedColumnId = null;
            return;
        }

        if (!state.schema.tables.some(table => table.id === state.selectedTableId)) {
            state.selectedTableId = state.schema.tables[0].id;
        }
        const table = state.schema.tables.find(candidate => candidate.id === state.selectedTableId);
        if (!table) {
            state.selectedTableId = null;
            state.selectedColumnId = null;
            return;
        }

        if (!table.columns.some(column => column.id === state.selectedColumnId)) {
            state.selectedColumnId = table.columns[0]?.id || null;
        }
    }

    function selectedTable() {
        return state.schema.tables.find(table => table.id === state.selectedTableId) || null;
    }

    function selectedColumn() {
        const table = selectedTable();
        return table ? table.columns.find(column => column.id === state.selectedColumnId) || null : null;
    }

    function findColumnById(columnId) {
        for (const table of state.schema.tables) {
            const column = table.columns.find(candidate => candidate.id === columnId);
            if (column) return { table, column };
        }
        return { table: null, column: null };
    }

    function relationColumns() {
        return state.schema.tables.flatMap(table => table.columns
            .filter(column => column.foreignKeyTable)
            .map(column => ({ table, column })));
    }

    function showToast(message) {
        elements.toast.textContent = message;
        elements.toast.hidden = false;
        clearTimeout(showToast.timer);
        showToast.timer = setTimeout(() => elements.toast.hidden = true, 3200);
    }

    function collaborationReady() {
        return Boolean(state.projectId && collaboration.connection && collaboration.connection.state === signalR.HubConnectionState.Connected);
    }

    function scheduleSchemaBroadcast(delay = 320) {
        if (state.applyingRemoteUpdate || !state.projectId || !collaboration.connection) return;
        clearTimeout(collaboration.schemaTimer);
        collaboration.schemaTimer = setTimeout(broadcastSchema, delay);
    }

    async function broadcastSchema() {
        if (state.applyingRemoteUpdate || !collaborationReady()) return;
        try {
            await collaboration.connection.invoke('BroadcastSchema', state.projectId, state.schema);
            elements.canvasTipText.textContent = 'Realtime synced.';
        } catch (error) {
            elements.canvasTipText.textContent = 'Realtime sync paused.';
        }
    }

    function applyRemoteSchema(schema, email) {
        state.applyingRemoteUpdate = true;
        normalizeSchema(schema || { projectName: 'GeneratedMvcApp', tables: [] });
        render();
        state.applyingRemoteUpdate = false;
        elements.canvasTipText.textContent = `Updated by ${email || 'teammate'}.`;
    }

    function updateRemoteCursor(cursor) {
        if (!cursor?.email || cursor.email === currentUserEmail) return;
        let cursorEl = collaboration.remoteCursors.get(cursor.email);
        if (!cursorEl) {
            cursorEl = document.createElement('div');
            cursorEl.className = 'remote-cursor';
            cursorEl.innerHTML = '<span class="remote-cursor-pointer"></span><strong></strong>';
            elements.remoteCursorLayer.appendChild(cursorEl);
            collaboration.remoteCursors.set(cursor.email, cursorEl);
        }

        cursorEl.style.transform = `translate(${Number(cursor.x) || 0}px, ${Number(cursor.y) || 0}px)`;
        cursorEl.style.setProperty('--cursor-color', cursor.color || colorFromEmail(cursor.email));
        cursorEl.querySelector('strong').textContent = cursor.email;
        clearTimeout(cursorEl.hideTimer);
        cursorEl.hidden = false;
        cursorEl.hideTimer = setTimeout(() => {
            cursorEl.hidden = true;
        }, 5000);
    }

    function removeRemoteCursor(email) {
        const cursorEl = collaboration.remoteCursors.get(email);
        if (!cursorEl) return;
        cursorEl.remove();
        collaboration.remoteCursors.delete(email);
    }

    async function startCollaboration() {
        if (!state.projectId) {
            elements.canvasTipText.textContent = 'Create or open a project to enable realtime collaboration.';
            return;
        }

        if (!window.signalR) {
            elements.canvasTipText.textContent = 'Realtime script did not load.';
            return;
        }

        collaboration.connection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/project-collaboration')
            .withAutomaticReconnect()
            .build();

        collaboration.connection.on('SchemaUpdated', applyRemoteSchema);
        collaboration.connection.on('CursorMoved', updateRemoteCursor);
        collaboration.connection.on('UserLeft', removeRemoteCursor);
        collaboration.connection.on('UserJoined', email => {
            elements.canvasTipText.textContent = `${email} joined this project.`;
        });
        collaboration.connection.onreconnected(async () => {
            try {
                await collaboration.connection.invoke('JoinProject', state.projectId);
                elements.canvasTipText.textContent = 'Realtime collaboration reconnected.';
            } catch {
                elements.canvasTipText.textContent = 'Could not rejoin realtime project.';
            }
        });

        try {
            await collaboration.connection.start();
            await collaboration.connection.invoke('JoinProject', state.projectId);
            elements.canvasTipText.textContent = 'Realtime collaboration is on.';
        } catch {
            elements.canvasTipText.textContent = 'Realtime collaboration is unavailable.';
        }
    }

    function broadcastCursor(event) {
        if (!collaborationReady()) return;
        const viewport = elements.canvasViewport;
        const rect = viewport.getBoundingClientRect();
        const x = (viewport.scrollLeft + event.clientX - rect.left) / state.zoom;
        const y = (viewport.scrollTop + event.clientY - rect.top) / state.zoom;
        if (collaboration.cursorTimer) return;
        collaboration.cursorTimer = setTimeout(async () => {
            collaboration.cursorTimer = null;
            try {
                await collaboration.connection.invoke('MoveCursor', state.projectId, x, y, collaboration.cursorColor);
            } catch {
                // Cursor updates are best-effort only.
            }
        }, 45);
    }

    function clampZoom(value) {
        return Math.max(minZoom, Math.min(maxZoom, Number(value) || state.zoom));
    }

    function tableHeight(table) {
        return headerHeight + Math.max(table.columns.length, 1) * rowHeight + 24;
    }

    function applyZoom() {
        const zoom = clampZoom(state.zoom);
        state.zoom = zoom;
        elements.canvas.style.width = `${Math.ceil(canvasSize.width * zoom)}px`;
        elements.canvas.style.height = `${Math.ceil(canvasSize.height * zoom)}px`;
        [elements.relationSvg, elements.tableLayer, elements.emptyCanvas].forEach(layer => {
            layer.style.transform = `scale(${zoom})`;
            layer.style.transformOrigin = '0 0';
        });
        elements.zoomLevelLabel.textContent = `${Math.round(zoom * 100)}%`;
        elements.zoomOutBtn.disabled = zoom <= minZoom + 0.001;
        elements.zoomInBtn.disabled = zoom >= maxZoom - 0.001;
    }

    function setZoom(nextZoom, anchorClientPoint = null) {
        const viewport = elements.canvasViewport;
        const oldZoom = state.zoom;
        const newZoom = clampZoom(nextZoom);
        const rect = viewport.getBoundingClientRect();
        const anchor = anchorClientPoint || {
            x: rect.left + viewport.clientWidth / 2,
            y: rect.top + viewport.clientHeight / 2
        };
        const anchorOffsetX = anchor.x - rect.left;
        const anchorOffsetY = anchor.y - rect.top;
        const contentX = (viewport.scrollLeft + anchorOffsetX) / oldZoom;
        const contentY = (viewport.scrollTop + anchorOffsetY) / oldZoom;

        state.zoom = newZoom;
        applyZoom();
        viewport.scrollLeft = Math.max(0, contentX * state.zoom - anchorOffsetX);
        viewport.scrollTop = Math.max(0, contentY * state.zoom - anchorOffsetY);
    }

    function fitView() {
        const viewport = elements.canvasViewport;
        if (state.schema.tables.length === 0) {
            state.zoom = 0.48;
            applyZoom();
            viewport.scrollLeft = 0;
            viewport.scrollTop = 0;
            return;
        }

        const padding = 90;
        const bounds = state.schema.tables.reduce((current, table) => ({
            minX: Math.min(current.minX, table.x),
            minY: Math.min(current.minY, table.y),
            maxX: Math.max(current.maxX, table.x + tableWidth),
            maxY: Math.max(current.maxY, table.y + tableHeight(table))
        }), { minX: Infinity, minY: Infinity, maxX: -Infinity, maxY: -Infinity });

        const targetWidth = Math.max(1, bounds.maxX - bounds.minX + padding * 2);
        const targetHeight = Math.max(1, bounds.maxY - bounds.minY + padding * 2);
        state.zoom = clampZoom(Math.min(viewport.clientWidth / targetWidth, viewport.clientHeight / targetHeight, 0.9));
        applyZoom();
        viewport.scrollLeft = Math.max(0, (bounds.minX - padding) * state.zoom);
        viewport.scrollTop = Math.max(0, (bounds.minY - padding) * state.zoom);
    }

    function render() {
        const activeEl = document.activeElement;
        let focusSelector = null;
        let selectionStart = null;
        let selectionEnd = null;

        if (activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'TEXTAREA' || activeEl.tagName === 'SELECT')) {
            if (activeEl.hasAttribute('data-edit-table-name')) {
                focusSelector = '[data-edit-table-name]';
            } else if (activeEl.hasAttribute('data-edit-column-name')) {
                const columnId = activeEl.getAttribute('data-column-id');
                focusSelector = `[data-edit-column-name][data-column-id="${columnId}"]`;
            } else if (activeEl.hasAttribute('data-edit-column-type')) {
                const columnId = activeEl.getAttribute('data-column-id');
                focusSelector = `[data-edit-column-type][data-column-id="${columnId}"]`;
            } else if (activeEl.hasAttribute('data-edit-pk')) {
                const columnId = activeEl.getAttribute('data-column-id');
                focusSelector = `[data-edit-pk][data-column-id="${columnId}"]`;
            } else if (activeEl.hasAttribute('data-edit-nullable')) {
                const columnId = activeEl.getAttribute('data-column-id');
                focusSelector = `[data-edit-nullable][data-column-id="${columnId}"]`;
            } else if (activeEl.hasAttribute('data-edit-unique')) {
                const columnId = activeEl.getAttribute('data-column-id');
                focusSelector = `[data-edit-unique][data-column-id="${columnId}"]`;
            } else if (activeEl.hasAttribute('data-edit-fk-table')) {
                focusSelector = '[data-edit-fk-table]';
            } else if (activeEl.hasAttribute('data-edit-fk-column')) {
                focusSelector = '[data-edit-fk-column]';
            } else if (activeEl.id) {
                focusSelector = `#${activeEl.id}`;
            }

            if (focusSelector) {
                try {
                    selectionStart = activeEl.selectionStart;
                    selectionEnd = activeEl.selectionEnd;
                } catch (e) {
                    // ignore if not supported by input type
                }
            }
        }

        state.schema.projectName = elements.projectName.value || 'GeneratedMvcApp';
        const table = selectedTable();
        const selectedRelations = table
            ? relationColumns().filter(relation => relation.table.id === table.id || relation.column.foreignKeyTable.toLowerCase() === table.name.toLowerCase()).length
            : 0;
        elements.sqlStats.textContent = `${state.schema.tables.length} tables`;
        elements.tableCount.textContent = state.schema.tables.length;
        elements.relationCount.textContent = `${relationColumns().length} relations`;
        elements.selectedTableName.textContent = table?.name || 'No table';
        elements.sidebarColumnCount.textContent = `${table?.columns.length || 0} columns`;
        elements.sidebarRelationCount.textContent = `${selectedRelations} relations`;
        elements.canvasSelectedName.textContent = table?.name || 'none';
        elements.footerProjectName.textContent = state.schema.projectName;
        elements.footerSelectedTable.textContent = table?.name || 'none';
        elements.tablesPane.hidden = state.sideMode !== 'tables';
        elements.propertiesPane.hidden = state.sideMode !== 'properties';
        document.querySelectorAll('[data-side-mode]').forEach(button => {
            button.classList.toggle('active', button.dataset.sideMode === state.sideMode);
        });
        elements.emptyCanvas.hidden = state.schema.tables.length > 0;
        renderTableList();
        renderCanvasTables();
        renderRelations();
        renderInspector();
        applyZoom();

        if (focusSelector) {
            const newActiveEl = document.querySelector(focusSelector);
            if (newActiveEl) {
                newActiveEl.focus();
                if (selectionStart !== null && selectionEnd !== null) {
                    try {
                        newActiveEl.setSelectionRange(selectionStart, selectionEnd);
                    } catch (e) {
                        // ignore if not supported
                    }
                }
            }
        }
    }

    function renderTableList() {
        const query = state.tableSearch.trim().toLowerCase();
        const tables = query
            ? state.schema.tables.filter(table =>
                table.name.toLowerCase().includes(query) ||
                table.columns.some(column => column.name.toLowerCase().includes(query) || column.sqlType.toLowerCase().includes(query)))
            : state.schema.tables;

        if (state.schema.tables.length === 0) {
            elements.tableList.innerHTML = '<div class="empty-list">No tables yet.</div>';
            return;
        }

        if (tables.length === 0) {
            elements.tableList.innerHTML = '<div class="empty-list">No matching tables.</div>';
            return;
        }

        elements.tableList.innerHTML = tables.map(table => {
            const isActive = table.id === state.selectedTableId;
            const relations = table.columns.filter(column => column.foreignKeyTable).length;
            const previewColumns = table.columns
                .slice(0, 5)
                .map(column => `
                    <li>
                        <span class="${column.isPrimaryKey ? 'column-dot pk' : column.foreignKeyTable ? 'column-dot fk' : 'column-dot'}"></span>
                        ${escapeHtml(column.name)}
                    </li>
                `).join('');
            return `
                <article class="table-list-item ${isActive ? 'active' : ''}">
                    <button class="table-list-main" type="button" data-select-table="${table.id}">
                        <span class="table-list-name">v ${escapeHtml(table.name)}</span>
                        <small>${table.columns.length}</small>
                    </button>
                    ${isActive ? `
                        <div class="table-mini-meta">
                            <span>${table.columns.length} cols</span>
                            <span>${table.columns.filter(column => column.isPrimaryKey).length} PK</span>
                            <span>${relations} FK</span>
                        </div>
                        <ul class="table-column-preview">${previewColumns}</ul>
                        ${table.columns.length > 5 ? `<p class="more-line">+ ${table.columns.length - 5} more</p>` : ''}
                    ` : ''}
