    function relationCountForTable(table) {
        return relationColumns().filter(relation =>
            relation.table.id === table.id ||
            relation.column.foreignKeyTable.toLowerCase() === table.name.toLowerCase()).length;
    }

    function apiReadyCount(table) {
        return table.columns.filter(column => column.isPrimaryKey || column.foreignKeyTable || column.isUnique).length;
    }

