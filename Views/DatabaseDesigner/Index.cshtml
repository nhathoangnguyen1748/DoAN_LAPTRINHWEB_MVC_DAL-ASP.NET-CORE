@{
    ViewData["Title"] = "Database Designer";
}

<section class="designer-shell">
    <aside class="designer-panel designer-sidebar">
  

        <label class="field-label" for="projectName">Project name</label>
        <input id="projectName" class="text-input" value="GeneratedMvcApp" />

        <div class="sql-card">
            <div class="panel-title-row">
                <div>
                    <p class="section-kicker">SQL Import</p>
                    <h2>Import database structure</h2>
                </div>
                <span id="sqlStats" class="soft-pill">0 tables</span>
            </div>
            <textarea id="sqlInput" class="sql-input" spellcheck="false" placeholder="Paste CREATE TABLE statements here..."></textarea>
            <button id="importSqlBtn" class="btn btn-primary" type="button">Import SQL</button>
        </div>

        <div class="action-grid">
            <button id="addTableBtn" class="btn btn-light" type="button">Add table</button>
            <button id="reviewBtn" class="btn btn-ai" type="button">
                <span class="btn-spinner" aria-hidden="true"></span>
                <span id="reviewBtnText">AI Review Database</span>
            </button>
            <button id="exportBtn" class="btn btn-dark" type="button">Export MVC + SQL Server</button>
        </div>

        <div class="table-list-card">
            <div class="panel-title-row compact">
                <h2>Tables</h2>
                <span id="tableCount" class="soft-pill">0</span>
            </div>
            <div id="tableList" class="table-list"></div>
        </div>
    </aside>

    <main class="designer-panel designer-canvas-panel">
        <div class="canvas-toolbar">
            <div>
                <p class="section-kicker">Schema canvas</p>
                <h2>SQL Server diagram</h2>
                <p>Drag tables on the canvas. Foreign keys are drawn as clear orthogonal relationship lines.</p>
            </div>
            <div class="toolbar-metrics">
                <span id="relationCount" class="soft-pill">0 relations</span>
                <button id="autoLayoutBtn" class="btn btn-light" type="button">Auto layout</button>
            </div>
        </div>

        <div id="canvasViewport" class="canvas-viewport">
            <div id="canvas" class="schema-canvas">
                <svg id="relationSvg" class="relation-svg" width="1800" height="1200" viewBox="0 0 1800 1200" aria-hidden="true">
                    <defs>
                        <marker id="arrowHead" markerWidth="10" markerHeight="10" refX="7" refY="3" orient="auto" markerUnits="strokeWidth">
                            <path d="M0,0 L0,6 L7,3 z" fill="#1d6fe8"></path>
                        </marker>
                    </defs>
                </svg>
                <div id="tableLayer" class="table-layer"></div>
                <div id="emptyCanvas" class="empty-canvas">
                    <div class="empty-icon">+</div>
                    <h3>No tables yet</h3>
                    <p>Paste SQL or add tables manually to start designing.</p>
                </div>
            </div>
        </div>
    </main>

    <aside class="designer-panel inspector-panel">
        <div class="panel-title-row">
            <div>
                <p class="section-kicker">Inspector</p>
                <h2>Properties</h2>
            </div>
        </div>
        <div id="inspectorContent" class="inspector-content"></div>
    </aside>
</section>

<div id="reviewOverlay" class="review-overlay" hidden>
    <div class="review-dialog">
        <div class="review-header">
            <div>
                <p class="section-kicker">AI Database Review</p>
                <h2 id="reviewTitle">Relationship review</h2>
                <p id="reviewSource">Database links only</p>
            </div>
            <button id="closeReviewBtn" class="icon-btn" type="button" aria-label="Close review">×</button>
        </div>
        <div class="review-summary-grid">
            <div><strong id="issueTotal">0</strong><span>Issues</span></div>
            <div class="high"><strong id="issueHigh">0</strong><span>High</span></div>
            <div class="medium"><strong id="issueMedium">0</strong><span>Medium</span></div>
            <div class="low"><strong id="issueLow">0</strong><span>Low</span></div>
        </div>
        <div id="reviewIssues" class="review-issues"></div>
    </div>
</div>

<div id="toast" class="toast-message" hidden></div>

@section Scripts {
<script>
(() => {
    const canvasSize = { width: 1800, height: 1200 };
    const tableWidth = 300;
    const headerHeight = 86;
    const rowHeight = 34;
    const state = {
        schema: { projectName: 'GeneratedMvcApp', tables: [] },
        selectedTableId: null,
        selectedColumnId: null,
        dragging: null
    };

    const elements = {
        projectName: document.getElementById('projectName'),
        sqlInput: document.getElementById('sqlInput'),
        importSqlBtn: document.getElementById('importSqlBtn'),
        addTableBtn: document.getElementById('addTableBtn'),
        autoLayoutBtn: document.getElementById('autoLayoutBtn'),
        reviewBtn: document.getElementById('reviewBtn'),
        reviewBtnText: document.getElementById('reviewBtnText'),
        exportBtn: document.getElementById('exportBtn'),
        sqlStats: document.getElementById('sqlStats'),
        tableCount: document.getElementById('tableCount'),
        relationCount: document.getElementById('relationCount'),
        tableList: document.getElementById('tableList'),
        tableLayer: document.getElementById('tableLayer'),
        relationSvg: document.getElementById('relationSvg'),
        emptyCanvas: document.getElementById('emptyCanvas'),
        inspectorContent: document.getElementById('inspectorContent'),
        reviewOverlay: document.getElementById('reviewOverlay'),
        closeReviewBtn: document.getElementById('closeReviewBtn'),
        reviewTitle: document.getElementById('reviewTitle'),
        reviewSource: document.getElementById('reviewSource'),
        issueTotal: document.getElementById('issueTotal'),
        issueHigh: document.getElementById('issueHigh'),
        issueMedium: document.getElementById('issueMedium'),
        issueLow: document.getElementById('issueLow'),
        reviewIssues: document.getElementById('reviewIssues'),
        toast: document.getElementById('toast')
    };

    function uid() {
        if (window.crypto && crypto.randomUUID) {
            return crypto.randomUUID().replaceAll('-', '');
        }
        return Math.random().toString(16).slice(2) + Date.now().toString(16);
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function normalizeSchema(schema) {
        state.schema = {
            projectName: schema.projectName || elements.projectName.value || 'GeneratedMvcApp',
            tables: (schema.tables || []).map((table, tableIndex) => ({
                id: table.id || uid(),
                name: table.name || `table_${tableIndex + 1}`,
                x: Number.isFinite(Number(table.x)) ? Number(table.x) : 80 + (tableIndex % 3) * 380,
                y: Number.isFinite(Number(table.y)) ? Number(table.y) : 80 + Math.floor(tableIndex / 3) * 320,
                columns: (table.columns || []).map((column, columnIndex) => ({
                    id: column.id || uid(),
                    name: column.name || `column_${columnIndex + 1}`,
                    sqlType: column.sqlType || 'nvarchar(255)',
                    isPrimaryKey: Boolean(column.isPrimaryKey),
                    isNullable: column.isPrimaryKey ? false : column.isNullable !== false,
                    isUnique: Boolean(column.isUnique),
                    foreignKeyTable: column.foreignKeyTable || '',
                    foreignKeyColumn: column.foreignKeyColumn || '',
                    order: Number.isFinite(Number(column.order)) ? Number(column.order) : columnIndex
                }))
            }))
        };
        elements.projectName.value = state.schema.projectName;
        if (!state.selectedTableId && state.schema.tables.length > 0) {
            state.selectedTableId = state.schema.tables[0].id;
        }
    }

    function selectedTable() {
        return state.schema.tables.find(table => table.id === state.selectedTableId) || null;
    }

    function selectedColumn() {
        const table = selectedTable();
        return table ? table.columns.find(column => column.id === state.selectedColumnId) || null : null;
    }

    function relationColumns() {
        return state.schema.tables.flatMap(table => table.columns
            .filter(column => column.foreignKeyTable)
            .map(column => ({ table, column })));
    }

    function showToast(message) {
        elements.toast.textContent = message;
        elements.toast.hidden = false;
        clearTimeout(showToast.timer);
        showToast.timer = setTimeout(() => elements.toast.hidden = true, 3200);
    }

    function render() {
        state.schema.projectName = elements.projectName.value || 'GeneratedMvcApp';
        elements.sqlStats.textContent = `${state.schema.tables.length} tables`;
        elements.tableCount.textContent = state.schema.tables.length;
        elements.relationCount.textContent = `${relationColumns().length} relations`;
        elements.emptyCanvas.hidden = state.schema.tables.length > 0;
        renderTableList();
        renderCanvasTables();
        renderRelations();
        renderInspector();
    }

    function renderTableList() {
        if (state.schema.tables.length === 0) {
            elements.tableList.innerHTML = '<div class="empty-list">No tables yet.</div>';
            return;
        }

        elements.tableList.innerHTML = state.schema.tables.map(table => `
            <button class="table-list-item ${table.id === state.selectedTableId ? 'active' : ''}" type="button" data-select-table="${table.id}">
                <span>${escapeHtml(table.name)}</span>
                <small>${table.columns.length} cols</small>
            </button>
        `).join('');
    }

    function renderCanvasTables() {
        elements.tableLayer.innerHTML = state.schema.tables.map(table => {
            const rows = table.columns
                .sort((a, b) => a.order - b.order)
                .map(column => {
                    const badges = [];
                    if (column.isPrimaryKey) badges.push('<span class="badge pk">PK</span>');
                    if (column.foreignKeyTable) badges.push('<span class="badge fk">FK</span>');
                    if (column.isUnique) badges.push('<span class="badge uq">UQ</span>');
                    return `
                        <button class="table-row ${column.id === state.selectedColumnId ? 'active' : ''}" type="button" data-select-column="${table.id}:${column.id}">
                            <span class="column-name">${escapeHtml(column.name)}</span>
                            <span class="column-type">${escapeHtml(column.sqlType)}</span>
                            <span class="column-badges">${badges.join('')}</span>
                        </button>
                    `;
                }).join('');

            return `
                <article class="schema-table ${table.id === state.selectedTableId ? 'selected' : ''}" style="transform: translate(${table.x}px, ${table.y}px);" data-table-id="${table.id}">
                    <header class="schema-table-header" data-drag-table="${table.id}">
                        <div>
                            <small>table</small>
                            <h3>${escapeHtml(table.name)}</h3>
                        </div>
                        <span>${table.columns.length} cols</span>
                    </header>
                    <div class="schema-table-body">${rows || '<div class="empty-columns">No columns</div>'}</div>
                </article>
            `;
        }).join('');
    }

    function renderRelations() {
        const defs = elements.relationSvg.querySelector('defs')?.outerHTML || '';
        const paths = [];
        const labels = [];
        const relations = relationColumns();

        relations.forEach((relation, index) => {
            const targetTable = state.schema.tables.find(table => table.name.toLowerCase() === relation.column.foreignKeyTable.toLowerCase());
            if (!targetTable) return;

            const targetColumnName = relation.column.foreignKeyColumn || 'id';
            const targetColumn = targetTable.columns.find(column => column.name.toLowerCase() === targetColumnName.toLowerCase()) || targetTable.columns.find(column => column.isPrimaryKey) || targetTable.columns[0];
            if (!targetColumn) return;

            const leftToRight = relation.table.x <= targetTable.x;
            const start = columnAnchor(relation.table, relation.column, leftToRight ? 'right' : 'left');
            const end = columnAnchor(targetTable, targetColumn, leftToRight ? 'left' : 'right');
            const offset = 26 + (index % 5) * 18;
            const midX = leftToRight ? Math.max(start.x + offset, (start.x + end.x) / 2) : Math.min(start.x - offset, (start.x + end.x) / 2);
            const d = `M ${start.x} ${start.y} L ${midX} ${start.y} L ${midX} ${end.y} L ${end.x} ${end.y}`;

            paths.push(`<path class="relation-path" d="${d}" marker-end="url(#arrowHead)"></path>`);
            labels.push(`<text class="relation-label" x="${end.x + (leftToRight ? -44 : 14)}" y="${end.y - 8}">1</text>`);
            labels.push(`<text class="relation-label many" x="${start.x + (leftToRight ? 12 : -46)}" y="${start.y - 8}">1..*</text>`);
        });

        elements.relationSvg.innerHTML = defs + paths.join('') + labels.join('');
    }

    function columnAnchor(table, column, side) {
        const sorted = [...table.columns].sort((a, b) => a.order - b.order);
        const index = Math.max(0, sorted.findIndex(candidate => candidate.id === column.id));
        return {
            x: table.x + (side === 'right' ? tableWidth : 0),
            y: table.y + headerHeight + index * rowHeight + rowHeight / 2
        };
    }

    function renderInspector() {
        const table = selectedTable();
        const column = selectedColumn();

        if (!table) {
            elements.inspectorContent.innerHTML = `
                <div class="empty-inspector">
                    <h3>Select a table</h3>
                    <p>Click a table on the canvas to edit columns and relationships.</p>
                </div>
            `;
            return;
        }

        const fkTableOptions = ['<option value="">No relationship</option>']
            .concat(state.schema.tables
                .filter(candidate => candidate.id !== table.id)
                .map(candidate => `<option value="${escapeHtml(candidate.name)}" ${column?.foreignKeyTable === candidate.name ? 'selected' : ''}>${escapeHtml(candidate.name)}</option>`))
            .join('');

        const targetTable = column?.foreignKeyTable
            ? state.schema.tables.find(candidate => candidate.name.toLowerCase() === column.foreignKeyTable.toLowerCase())
            : null;
        const fkColumnOptions = targetTable
            ? targetTable.columns.map(candidate => `<option value="${escapeHtml(candidate.name)}" ${column?.foreignKeyColumn === candidate.name ? 'selected' : ''}>${escapeHtml(candidate.name)}</option>`).join('')
            : '<option value="">Target column</option>';

        elements.inspectorContent.innerHTML = `
            <div class="editor-section">
                <label class="field-label">Table name</label>
                <input class="text-input" data-edit-table-name value="${escapeHtml(table.name)}" />
                <div class="mini-actions">
                    <button class="btn btn-light" type="button" data-add-column>Add column</button>
                    <button class="btn btn-danger" type="button" data-delete-table>Delete table</button>
                </div>
            </div>
            <div class="editor-section">
                <h3>Columns</h3>
                <div class="inspector-column-list">
                    ${table.columns.map(col => `
                        <button class="inspector-column ${col.id === state.selectedColumnId ? 'active' : ''}" type="button" data-select-column="${table.id}:${col.id}">
                            <span>${escapeHtml(col.name)}</span><small>${escapeHtml(col.sqlType)}</small>
                        </button>
                    `).join('') || '<p class="muted">No columns yet.</p>'}
                </div>
            </div>
            ${column ? `
            <div class="editor-section">
                <h3>Column detail</h3>
                <label class="field-label">Column name</label>
                <input class="text-input" data-edit-column-name value="${escapeHtml(column.name)}" />
                <label class="field-label">SQL Server type</label>
                <input class="text-input" data-edit-column-type value="${escapeHtml(column.sqlType)}" />
                <div class="check-grid">
                    <label><input type="checkbox" data-edit-pk ${column.isPrimaryKey ? 'checked' : ''} /> Primary key</label>
                    <label><input type="checkbox" data-edit-nullable ${column.isNullable ? 'checked' : ''} ${column.isPrimaryKey ? 'disabled' : ''} /> Nullable</label>
                    <label><input type="checkbox" data-edit-unique ${column.isUnique ? 'checked' : ''} /> Unique</label>
                </div>
                <label class="field-label">Relationship target table</label>
                <select class="text-input" data-edit-fk-table>${fkTableOptions}</select>
                <label class="field-label">Target column</label>
                <select class="text-input" data-edit-fk-column>${fkColumnOptions}</select>
                <button class="btn btn-danger wide" type="button" data-delete-column>Delete column</button>
            </div>` : ''}
        `;
    }

    function autoLayout() {
        const roots = [...state.schema.tables].sort((a, b) => inboundCount(a) - inboundCount(b));
        roots.forEach((table, index) => {
            table.x = 80 + (index % 3) * 390;
            table.y = 80 + Math.floor(index / 3) * 330;
        });
        render();
    }

    function inboundCount(table) {
        return relationColumns().filter(relation => relation.column.foreignKeyTable.toLowerCase() === table.name.toLowerCase()).length;
    }

    function addTable() {
        const next = state.schema.tables.length + 1;
        const table = {
            id: uid(),
            name: `new_table_${next}`,
            x: 80 + ((next - 1) % 3) * 390,
            y: 80 + Math.floor((next - 1) / 3) * 330,
            columns: [{ id: uid(), name: 'id', sqlType: 'int', isPrimaryKey: true, isNullable: false, isUnique: false, foreignKeyTable: '', foreignKeyColumn: '', order: 0 }]
        };
        state.schema.tables.push(table);
        state.selectedTableId = table.id;
        state.selectedColumnId = table.columns[0].id;
        render();
    }

    function addColumn(table) {
        const column = {
            id: uid(),
            name: `column_${table.columns.length + 1}`,
            sqlType: 'nvarchar(255)',
            isPrimaryKey: false,
            isNullable: true,
            isUnique: false,
            foreignKeyTable: '',
            foreignKeyColumn: '',
            order: table.columns.length
        };
        table.columns.push(column);
        state.selectedColumnId = column.id;
        render();
    }

    function stripComments(sql) {
        let result = sql.replace(/\/\*[\s\S]*?\*\//g, '');
        result = result.replace(/(--|#).*?$/gm, '');
        return result;
    }

    function findMatchingParenthesis(text, openIndex) {
        let depth = 0;
        let quote = null;
        let inBracket = false;
        for (let i = openIndex; i < text.length; i++) {
            const char = text[i];
            if (inBracket) {
                if (char === ']') inBracket = false;
                continue;
            }
            if (quote !== null) {
                if (char === quote) quote = null;
                continue;
            }
            if (char === '[') {
                inBracket = true;
                continue;
            }
            if (char === '\'' || char === '"' || char === '`') {
                quote = char;
                continue;
            }
            if (char === '(') {
                depth++;
            } else if (char === ')') {
                depth--;
                if (depth === 0) return i;
            }
        }
        return -1;
    }

    function skipWhitespace(text, index) {
        while (index < text.length && /\s/.test(text[index])) {
            index++;
        }
        return index;
    }

    function readIdentifierToken(text, startIndex, setEndIndex) {
        let endIndex = skipWhitespace(text, startIndex);
        if (endIndex >= text.length) {
            setEndIndex(endIndex);
            return '';
        }
        const first = text[endIndex];
        if (first === '[') {
            const close = text.indexOf(']', endIndex + 1);
            if (close >= 0) {
                const token = text.substring(endIndex, close + 1);
                setEndIndex(close + 1);
                return token;
            }
        }
        if (first === '"' || first === '`') {
            const close = text.indexOf(first, endIndex + 1);
            if (close >= 0) {
                const token = text.substring(endIndex, close + 1);
                setEndIndex(close + 1);
                return token;
            }
        }
        let cursor = endIndex;
        while (cursor < text.length && !/\s/.test(text[cursor]) && text[cursor] !== '(' && text[cursor] !== ')' && text[cursor] !== ',' && text[cursor] !== ';') {
            cursor++;
        }
        const result = text.substring(endIndex, cursor);
        setEndIndex(cursor);
        return result;
    }

    function splitTopLevel(text, separator) {
        const parts = [];
        let builder = '';
        let depth = 0;
        let quote = null;
        let inBracket = false;
        for (let i = 0; i < text.length; i++) {
            const character = text[i];
            if (inBracket) {
                builder += character;
                if (character === ']') inBracket = false;
                continue;
            }
            if (quote !== null) {
                builder += character;
                if (character === quote) quote = null;
                continue;
            }
            if (character === '[') {
                inBracket = true;
                builder += character;
                continue;
            }
            if (character === '\'' || character === '"' || character === '`') {
                quote = character;
                builder += character;
                continue;
            }
            if (character === '(') {
                depth++;
            } else if (character === ')' && depth > 0) {
                depth--;
            }
            if (character === separator && depth === 0) {
                parts.push(builder);
                builder = '';
            } else {
                builder += character;
            }
        }
        if (builder.length > 0) {
            parts.push(builder);
        }
        return parts;
    }

    function stripConstraintName(definition) {
        let trimmed = definition.trim();
        if (!trimmed.toUpperCase().startsWith("CONSTRAINT")) {
            return definition;
        }
        let nameEnd;
        readIdentifierToken(trimmed, "CONSTRAINT".length, (endIdx) => { nameEnd = endIdx; });
        return nameEnd < trimmed.length ? trimmed.substring(nameEnd) : '';
    }

    function normalizeIdentifier(identifier) {
        let normalized = identifier.trim();
        if (normalized.endsWith(';')) {
            normalized = normalized.slice(0, -1).trim();
        }
        if (normalized.startsWith('[') && normalized.endsWith(']')) {
            normalized = normalized.slice(1, -1);
        } else if ((normalized.startsWith('"') && normalized.endsWith('"')) || (normalized.startsWith('`') && normalized.endsWith('`'))) {
            normalized = normalized.slice(1, -1);
        }
        return normalized.trim();
    }

    function getLastIdentifierPart(identifier) {
        const parts = splitTopLevel(identifier, '.').map(normalizeIdentifier).filter(Boolean);
        return parts[parts.length - 1] || normalizeIdentifier(identifier);
    }

    function readColumnsFromParentheses(text) {
        const open = text.indexOf('(');
        if (open < 0) return [];
        const close = findMatchingParenthesis(text, open);
        if (close <= open) return [];
        return splitTopLevel(text.substring(open + 1, close), ',')
            .map(column => normalizeIdentifier(getLastIdentifierPart(column.trim())))
            .filter(Boolean);
    }

    function parseColumnDefinition(definition, order) {
        let nameEnd;
        const columnName = readIdentifierToken(definition, 0, (endIdx) => { nameEnd = endIdx; });
        if (!columnName) return null;
        const rest = nameEnd < definition.length ? definition.substring(nameEnd).trim() : '';
        const stopWords = ["CONSTRAINT", "PRIMARY", "FOREIGN", "REFERENCES", "UNIQUE", "NULL", "NOT", "DEFAULT", "CHECK", "COLLATE"];
        const tokens = splitTopLevel(rest, ' ').map(t => t.trim()).filter(Boolean);
        const typeTokens = [];
        for (let i = 0; i < tokens.length; i++) {
            const token = tokens[i];
            const keyword = token.toUpperCase();
            if (stopWords.includes(keyword) || (keyword === 'KEY' && typeTokens.length > 0 && typeTokens[typeTokens.length - 1].toUpperCase() === 'PRIMARY')) {
                break;
            }
            typeTokens.push(token);
        }
        const sqlType = typeTokens.join(' ').trim() || 'nvarchar(255)';
        const isPrimaryKey = /\bPRIMARY\s+KEY\b/i.test(rest);
        const isNullable = !/\bNOT\s+NULL\b/i.test(rest) && !isPrimaryKey;
        const isUnique = /\bUNIQUE\b/i.test(rest);
        let foreignKeyTable = '';
        let foreignKeyColumn = '';
        const refMatch = rest.match(/\bREFERENCES\s+([a-zA-Z0-9_`"\[\]\.]+)\s*\(([^)]+)\)/i);
        if (refMatch) {
            foreignKeyTable = normalizeIdentifier(getLastIdentifierPart(refMatch[1]));
            foreignKeyColumn = normalizeIdentifier(refMatch[2]);
        } else {
            const refNoColMatch = rest.match(/\bREFERENCES\s+([a-zA-Z0-9_`"\[\]\.]+)(?!\s*\()/i);
            if (refNoColMatch) {
                foreignKeyTable = normalizeIdentifier(getLastIdentifierPart(refNoColMatch[1]));
                foreignKeyColumn = 'id';
            }
        }
        let defaultValue = '';
        const defaultMatch = rest.match(/\bDEFAULT\s+([^,)]+)/i);
        if (defaultMatch) {
            defaultValue = defaultMatch[1].trim();
        }
        return {
            id: uid(),
            name: normalizeIdentifier(getLastIdentifierPart(columnName)),
            sqlType: sqlType.replace(/\s+/g, ' '),
            isPrimaryKey: isPrimaryKey,
            isNullable: isNullable,
            isUnique: isUnique,
            foreignKeyTable: foreignKeyTable,
            foreignKeyColumn: foreignKeyColumn,
            defaultValue: defaultValue,
            order: order
        };
    }

    function parseTableForeignKey(definition) {
        const localCols = readColumnsFromParentheses(definition);
        let refIndex = -1;
        const upperDef = definition.toUpperCase();
        const match = upperDef.match(/\bREFERENCES\b/);
        if (match) {
            refIndex = match.index;
        } else {
            refIndex = upperDef.indexOf('REFERENCES');
        }
        if (refIndex < 0) return null;
        const afterRef = definition.substring(refIndex + 'REFERENCES'.length).trim();
        let tableEnd;
        const targetTable = readIdentifierToken(afterRef, 0, (endIdx) => { tableEnd = endIdx; });
        const remaining = tableEnd < afterRef.length ? afterRef.substring(tableEnd) : '';
        const targetCols = readColumnsFromParentheses(remaining);
        return {
            localCols: localCols,
            targetTable: normalizeIdentifier(getLastIdentifierPart(targetTable)),
            targetCols: targetCols.length > 0 ? targetCols : ['id']
        };
    }

    function parseSqlToTables(sqlText) {
        const cleaned = stripComments(sqlText);
        const createTableRegex = /\bCREATE\s+TABLE\b/gi;
        const blocks = [];
        let match;
        while ((match = createTableRegex.exec(cleaned)) !== null) {
            let cursor = match.index + match[0].length;
            const remaining = cleaned.substring(cursor).trimStart();
            const nameStartOffset = cleaned.substring(cursor).length - remaining.length;
            cursor += nameStartOffset;
            if (remaining.toUpperCase().startsWith("IF NOT EXISTS")) {
                cursor += "IF NOT EXISTS".length;
            }
            let endOfName;
            const tableName = readIdentifierToken(cleaned, cursor, (endIdx) => { endOfName = endIdx; });
            if (!tableName) continue;
            cursor = skipWhitespace(cleaned, endOfName);
            if (cursor < cleaned.length && cleaned[cursor] === '(') {
                const closeIndex = findMatchingParenthesis(cleaned, cursor);
                if (closeIndex > cursor) {
                    const body = cleaned.substring(cursor + 1, closeIndex);
                    blocks.push({
                        tableName: normalizeIdentifier(getLastIdentifierPart(tableName)),
                        body: body
                    });
                    createTableRegex.lastIndex = closeIndex + 1;
                }
            }
        }

        const tables = [];
        for (const block of blocks) {
            const table = {
                id: uid(),
                name: block.tableName,
                x: 0,
                y: 0,
                columns: []
            };
            const definitions = splitTopLevel(block.body, ',');
            const pendingPrimaryKeys = [];
            const pendingForeignKeys = [];
            const pendingUniqueCols = [];
            let order = 0;

            for (let def of definitions) {
                def = def.trim();
                if (!def) continue;
                const normalizedDef = stripConstraintName(def);
                const firstWordMatch = normalizedDef.match(/^\s*([a-zA-Z0-9_]+)/);
                const firstWord = firstWordMatch ? firstWordMatch[1].toUpperCase() : '';
                const tableConstraintWords = ["PRIMARY", "FOREIGN", "UNIQUE", "CHECK", "KEY", "CONSTRAINT"];
                if (tableConstraintWords.includes(firstWord)) {
                    const upperDef = normalizedDef.toUpperCase();
                    if (upperDef.startsWith('PRIMARY')) {
                        pendingPrimaryKeys.push(...readColumnsFromParentheses(normalizedDef));
                    } else if (upperDef.startsWith('FOREIGN')) {
                        const fk = parseTableForeignKey(normalizedDef);
                        if (fk && fk.localCols.length > 0 && fk.targetTable) {
                            pendingForeignKeys.push(fk);
                        }
                    } else if (upperDef.startsWith('UNIQUE')) {
                        const uniqueCols = readColumnsFromParentheses(normalizedDef);
                        uniqueCols.forEach(colName => {
                            pendingUniqueCols.push({ colName });
                        });
                    }
                    continue;
                }
                const column = parseColumnDefinition(def, order++);
                if (column && column.name) {
                    table.columns.push(column);
                }
            }

            for (const pkName of pendingPrimaryKeys) {
                const column = table.columns.find(c => c.name.toLowerCase() === pkName.toLowerCase());
                if (column) {
                    column.isPrimaryKey = true;
                    column.isNullable = false;
                }
            }

            for (const fk of pendingForeignKeys) {
                for (let i = 0; i < fk.localCols.length; i++) {
                    const colName = fk.localCols[i];
                    const column = table.columns.find(c => c.name.toLowerCase() === colName.toLowerCase());
                    if (column) {
                        column.foreignKeyTable = fk.targetTable;
                        column.foreignKeyColumn = i < fk.targetCols.length ? fk.targetCols[i] : 'id';
                    }
                }
            }

            for (const uniq of pendingUniqueCols) {
                const column = table.columns.find(c => c.name.toLowerCase() === uniq.colName.toLowerCase());
                if (column) {
                    column.isUnique = true;
                }
            }

            if (table.columns.length > 0) {
                tables.push(table);
            }
        }
        return tables;
    }

    function importSql() {
        const sql = elements.sqlInput.value.trim();
        let errorDiv = document.getElementById('sqlErrorMsg');
        if (!errorDiv) {
            errorDiv = document.createElement('div');
            errorDiv.id = 'sqlErrorMsg';
            errorDiv.style.color = '#dc2626';
            errorDiv.style.fontSize = '0.825rem';
            errorDiv.style.marginTop = '0.5rem';
            errorDiv.style.fontWeight = '500';
            elements.importSqlBtn.parentNode.appendChild(errorDiv);
        }

        if (!sql) {
            errorDiv.textContent = 'Paste SQL before importing.';
            errorDiv.hidden = false;
            return;
        }

        try {
            const parsedTables = parseSqlToTables(sql);
            if (parsedTables.length === 0) {
                throw new Error('No valid CREATE TABLE statements found.');
            }

            parsedTables.forEach(newTable => {
                const exists = state.schema.tables.some(t => t.name.toLowerCase() === newTable.name.toLowerCase());
                if (!exists) {
                    state.schema.tables.push(newTable);
                } else {
                    let uniqueName = newTable.name;
                    let count = 1;
                    while (state.schema.tables.some(t => t.name.toLowerCase() === uniqueName.toLowerCase())) {
                        uniqueName = `${newTable.name}_${count++}`;
                    }
                    newTable.name = uniqueName;
                    state.schema.tables.push(newTable);
                }
            });

            if (parsedTables.length > 0) {
                state.selectedTableId = parsedTables[0].id;
                state.selectedColumnId = parsedTables[0].columns[0]?.id || null;
            }

            errorDiv.textContent = '';
            errorDiv.hidden = true;
            elements.sqlInput.value = '';

            autoLayout();
            showToast(`Successfully imported ${parsedTables.length} table(s).`);
        } catch (error) {
            errorDiv.textContent = error.message || 'SQL parse failed.';
            errorDiv.hidden = false;
        }
    }

    async function reviewSchema() {
        if (state.schema.tables.length === 0) {
            showToast('Add or import tables before AI review.');
            return;
        }

        elements.reviewBtn.classList.add('loading');
        elements.reviewBtn.disabled = true;
        elements.reviewBtnText.textContent = 'Reviewing...';
        const startedAt = performance.now();
        try {
            const response = await fetch('/DatabaseDesigner/Review', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(state.schema)
            });
            if (!response.ok) throw new Error('AI review failed');
            showReview(await response.json());
        } catch (error) {
            showToast(error.message || 'AI review failed.');
        } finally {
            const elapsed = performance.now() - startedAt;
            if (elapsed < 700) {
                await new Promise(resolve => setTimeout(resolve, 700 - elapsed));
            }
            elements.reviewBtn.classList.remove('loading');
            elements.reviewBtn.disabled = false;
            elements.reviewBtnText.textContent = 'AI Review Database';
        }
    }

    function showReview(result) {
        const issues = result.issues || [];
        elements.reviewTitle.textContent = result.summary || 'Database review completed';
        elements.reviewSource.textContent = result.source || 'Database links only';
        elements.issueTotal.textContent = issues.length;
        elements.issueHigh.textContent = result.highCount ?? issues.filter(i => String(i.severity).toUpperCase() === 'HIGH').length;
        elements.issueMedium.textContent = result.mediumCount ?? issues.filter(i => String(i.severity).toUpperCase() === 'MEDIUM').length;
        elements.issueLow.textContent = result.lowCount ?? issues.filter(i => String(i.severity).toUpperCase() === 'LOW').length;
        elements.reviewIssues.innerHTML = issues.length === 0
            ? '<div class="review-empty"><strong>Looks clean.</strong><span>No database relationship issue was found.</span></div>'
            : issues.map(issue => `
                <article class="issue-card ${String(issue.severity || '').toLowerCase()}">
                    <div><span>${escapeHtml(issue.severity || 'LOW')}</span><strong>${escapeHtml(issue.type || 'ISSUE')}</strong></div>
                    <p>${escapeHtml(issue.message || '')}</p>
                    <small>${escapeHtml(issue.suggestion || '')}</small>
                </article>
            `).join('');
        elements.reviewOverlay.hidden = false;
    }

    async function exportProject() {
        if (state.schema.tables.length === 0) {
            showToast('Add or import tables before exporting.');
            return;
        }

        elements.exportBtn.disabled = true;
        try {
            const response = await fetch('/DatabaseDesigner/Export', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(state.schema)
            });
            if (!response.ok) throw new Error('Export failed');
            const blob = await response.blob();
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `${state.schema.projectName || 'GeneratedMvcApp'}-aspnet-mvc-sqlserver.zip`;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(url);
            showToast('Exported ASP.NET Core MVC + SQL Server source.');
        } catch (error) {
            showToast(error.message || 'Export failed.');
        } finally {
            elements.exportBtn.disabled = false;
        }
    }

    document.addEventListener('click', event => {
            const tableButton = event.target.closest('[data-select-table]');
        if (tableButton) {
            state.selectedTableId = tableButton.dataset.selectTable;
            state.selectedColumnId = selectedTable()?.columns[0]?.id || null;
            render();
            return;
        }

        const columnButton = event.target.closest('[data-select-column]');
        if (columnButton) {
            const [tableId, columnId] = columnButton.dataset.selectColumn.split(':');
            state.selectedTableId = tableId;
            state.selectedColumnId = columnId;
            render();
            return;
        }

        if (event.target.closest('[data-add-column]')) {
            const table = selectedTable();
            if (table) addColumn(table);
            return;
        }

        if (event.target.closest('[data-delete-table]')) {
            const table = selectedTable();
            if (!table) return;
            state.schema.tables = state.schema.tables.filter(candidate => candidate.id !== table.id);
            state.schema.tables.forEach(candidate => candidate.columns.forEach(column => {
                if (column.foreignKeyTable === table.name) {
                    column.foreignKeyTable = '';
                    column.foreignKeyColumn = '';
                }
            }));
            state.selectedTableId = state.schema.tables[0]?.id || null;
            state.selectedColumnId = state.schema.tables[0]?.columns[0]?.id || null;
            render();
            return;
        }

        if (event.target.closest('[data-delete-column]')) {
            const table = selectedTable();
            const column = selectedColumn();
            if (!table || !column) return;
            table.columns = table.columns.filter(candidate => candidate.id !== column.id);
            state.selectedColumnId = table.columns[0]?.id || null;
            render();
        }
    });

    document.addEventListener('input', event => {
        const table = selectedTable();
        const column = selectedColumn();

        if (event.target.matches('[data-edit-table-name]') && table) {
            const oldName = table.name;
            table.name = event.target.value;
            state.schema.tables.forEach(candidate => candidate.columns.forEach(col => {
                if (col.foreignKeyTable === oldName) col.foreignKeyTable = table.name;
            }));
            
            // Cập nhật nhãn tên bảng trên Sidebar
            const sidebarItem = document.querySelector(`[data-select-table="${table.id}"] span`);
            if (sidebarItem) sidebarItem.textContent = table.name;
            
            // Cập nhật nhãn tên bảng trên Canvas
            const canvasHeader = document.querySelector(`[data-table-id="${table.id}"] .schema-table-header h3`);
            if (canvasHeader) canvasHeader.textContent = table.name;

            // Vẽ lại các đường quan hệ
            renderRelations();
        }

        if (event.target.matches('[data-edit-column-name]') && column) {
            column.name = event.target.value;
            
            // Cập nhật nhãn tên cột trên Canvas
            const canvasColName = document.querySelector(`[data-select-column="${table.id}:${column.id}"] .column-name`);
            if (canvasColName) canvasColName.textContent = column.name;
            
            // Cập nhật nhãn tên cột trong danh sách cột ở Sidebar
            const inspectorColBtn = document.querySelector(`.inspector-column[data-select-column="${table.id}:${column.id}"] span`);
            if (inspectorColBtn) inspectorColBtn.textContent = column.name;
        }

        if (event.target.matches('[data-edit-column-type]') && column) {
            column.sqlType = event.target.value;
            
            // Cập nhật nhãn kiểu dữ liệu trên Canvas
            const canvasColType = document.querySelector(`[data-select-column="${table.id}:${column.id}"] .column-type`);
            if (canvasColType) canvasColType.textContent = column.sqlType;
            
            // Cập nhật nhãn kiểu dữ liệu trong danh sách cột ở Sidebar
            const inspectorColMuted = document.querySelector(`.inspector-column[data-select-column="${table.id}:${column.id}"] small`);
            if (inspectorColMuted) inspectorColMuted.textContent = column.sqlType;
        }
    });

    document.addEventListener('blur', event => {
        const table = selectedTable();
        const column = selectedColumn();

        if (event.target.matches('[data-edit-table-name]') && table) {
            render();
        } else if ((event.target.matches('[data-edit-column-name]') || event.target.matches('[data-edit-column-type]')) && column) {
            render();
        }
    }, true);

    document.addEventListener('change', event => {
        const column = selectedColumn();
        if (!column) return;

        if (event.target.matches('[data-edit-pk]')) {
            column.isPrimaryKey = event.target.checked;
            if (column.isPrimaryKey) column.isNullable = false;
            render();
        }

        if (event.target.matches('[data-edit-nullable]')) {
            column.isNullable = event.target.checked;
            render();
        }

        if (event.target.matches('[data-edit-unique]')) {
            column.isUnique = event.target.checked;
            render();
        }

        if (event.target.matches('[data-edit-fk-table]')) {
            column.foreignKeyTable = event.target.value;
            const targetTable = state.schema.tables.find(table => table.name === column.foreignKeyTable);
            column.foreignKeyColumn = targetTable?.columns.find(col => col.isPrimaryKey)?.name || targetTable?.columns[0]?.name || '';
            render();
        }

        if (event.target.matches('[data-edit-fk-column]')) {
            column.foreignKeyColumn = event.target.value;
            render();
        }
    });

    document.addEventListener('pointerdown', event => {
        const dragHandle = event.target.closest('[data-drag-table]');
        if (!dragHandle) return;
        const table = state.schema.tables.find(candidate => candidate.id === dragHandle.dataset.dragTable);
        if (!table) return;
        state.selectedTableId = table.id;
        state.dragging = {
            table,
            startX: event.clientX,
            startY: event.clientY,
            originX: table.x,
            originY: table.y
        };
        dragHandle.setPointerCapture?.(event.pointerId);
        render();
    });

    document.addEventListener('pointermove', event => {
        if (!state.dragging) return;
        const drag = state.dragging;
        drag.table.x = Math.max(24, Math.min(canvasSize.width - tableWidth - 24, drag.originX + event.clientX - drag.startX));
        drag.table.y = Math.max(24, Math.min(canvasSize.height - 180, drag.originY + event.clientY - drag.startY));
        renderCanvasTables();
        renderRelations();
    });

    document.addEventListener('pointerup', () => {
        state.dragging = null;
    });

    elements.projectName.addEventListener('input', render);
    elements.importSqlBtn.addEventListener('click', importSql);
    elements.autoLayoutBtn.addEventListener('click', autoLayout);
    elements.exportBtn.addEventListener('click', exportProject);
    elements.closeReviewBtn.addEventListener('click', () => elements.reviewOverlay.hidden = true);

    normalizeSchema(state.schema);
    render();
})();
</script>
}

