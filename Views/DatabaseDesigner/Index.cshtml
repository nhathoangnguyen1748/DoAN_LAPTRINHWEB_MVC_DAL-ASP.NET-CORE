    function autoLayout() {
        if (state.schema.tables.length === 0) return;

        const tables = state.schema.tables;
        const tableMap = new Map(tables.map(t => [t.name.toLowerCase(), t]));
        
        // Khá»Ÿi táº¡o táº§ng máº·c Ä‘á»‹nh cho má»i báº£ng
        const layers = new Map();
        tables.forEach(t => layers.set(t.id, 0));

        // DÃ¹ng thuáº­t toÃ¡n DFS tÃ­nh toÃ¡n táº§ng phá»¥ thuá»™c (depth of dependencies)
        const visited = new Set();
        const path = new Set();

        function calculateLayer(table) {
            if (path.has(table.id)) {
                return layers.get(table.id); // PhÃ¡t hiá»‡n chu ká»³, dÃ¹ng giÃ¡ trá»‹ hiá»‡n táº¡i
            }
            if (visited.has(table.id)) {
                return layers.get(table.id);
            }

            path.add(table.id);
            let maxParentLayer = -1;

            table.columns.forEach(col => {
                if (col.foreignKeyTable) {
                    const parentTable = tableMap.get(col.foreignKeyTable.toLowerCase());
                    if (parentTable && parentTable.id !== table.id) {
                        const parentLayer = calculateLayer(parentTable);
                        maxParentLayer = Math.max(maxParentLayer, parentLayer);
                    }
                }
            });

            path.delete(table.id);
            visited.add(table.id);

            const computedLayer = maxParentLayer + 1;
            layers.set(table.id, computedLayer);
            return computedLayer;
        }

        tables.forEach(table => calculateLayer(table));

        // NhÃ³m cÃ¡c báº£ng theo táº§ng
        const layerGroups = new Map();
        tables.forEach(table => {
            const layer = layers.get(table.id) || 0;
            if (!layerGroups.has(layer)) {
                layerGroups.set(layer, []);
            }
            layerGroups.get(layer).push(table);
        });

        // Bá»‘ trÃ­ tá»a Ä‘á»™
        const sortedLayerKeys = Array.from(layerGroups.keys()).sort((a, b) => a - b);
        const startX = 85;
        const startY = 55;
        const colWidth = 360; // Khoáº£ng cÃ¡ch cá»™t Ä‘á»§ rá»™ng cho Ä‘Æ°á»ng ná»‘i Bezier
        const rowGap = 40;    // Khoáº£ng cÃ¡ch tá»‘i thiá»ƒu giá»¯a cÃ¡c báº£ng cÃ¹ng cá»™t

        sortedLayerKeys.forEach((layerKey, colIndex) => {
            const group = layerGroups.get(layerKey) || [];
            let currentY = startY;
            const x = startX + colIndex * colWidth;

            group.forEach(table => {
                table.x = x;
                table.y = currentY;
                currentY += tableHeight(table) + rowGap;
            });
        });

        // Giá»›i háº¡n trong vÃ¹ng canvasViewport
        tables.forEach(table => {
            table.x = Math.max(24, Math.min(canvasSize.width - tableWidth - 24, table.x));
            table.y = Math.max(24, Math.min(canvasSize.height - tableHeight(table) - 24, table.y));
        });

        render();
        scheduleSchemaBroadcast();
    }

    function inboundCount(table) {
        return relationColumns().filter(relation => relation.column.foreignKeyTable.toLowerCase() === table.name.toLowerCase()).length;
    }

