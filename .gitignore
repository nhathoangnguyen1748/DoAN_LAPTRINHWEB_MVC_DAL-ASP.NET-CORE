## Ignore Visual Studio temporary files, build results, and user-specific settings.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
bin/
obj/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userprev
*.userosscache
*.sln.docstates

# dotnet publish output
publish/

# Rider
.idea/
*.sln.iml

# OS/editor files
.DS_Store
Thumbs.db

# Logs
*.log

# Local environment files
.env
.env.*
!.env.example

# Runtime project data
App_Data/*.json

